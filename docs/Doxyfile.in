PROJECT_NAME           = "MiMMO (Minimal Memory Manager for OpenACC)"
PROJECT_BRIEF          = "A simple, safe, and easy-to-use CPU/GPU memory manager to work with OpenACC."
PROJECT_NUMBER         = @MiMMO_VERSION@
OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs"
INPUT                  = "@CMAKE_SOURCE_DIR@/include" "@CMAKE_SOURCE_DIR@/examples" "@CMAKE_SOURCE_DIR@/README.md"
RECURSIVE              = YES
GENERATE_LATEX         = NO
USE_MDFILE_AS_MAINPAGE = "@CMAKE_SOURCE_DIR@/README.md"
EXAMPLE_PATH           = "@CMAKE_SOURCE_DIR@/examples"
EXAMPLE_RECURSIVE      = YES

EXTENSION_MAPPING      = hpp=C++
HAVE_DOT               = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DIRECTORY_GRAPH        = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE_HUE    = 200
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
GENERATE_TREEVIEW      = YES
TOC_EXPAND             = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES

OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_OUTPUT_FOR_CPP = YES
BUILTIN_STL_SUPPORT    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION     = YES
REFERENCES_LINK_SOURCE  = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_PACKAGE        = YES
EXTRACT_STATIC         = YES
